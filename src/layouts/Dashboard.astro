---
// src/layouts/Dashboard.astro
import Base from './Base.astro';
export interface Props {
  title?: string;
  activeNav?: string;
}
const { title, activeNav } = Astro.props;

const nav = [
  { id: 'dashboard', href: '/dashboard', label: '대시보드', icon: '⊞' },
  { id: 'sites', href: '/dashboard/sites', label: '내 사이트', icon: '🌐' },
  { id: 'create', href: '/dashboard/create', label: '사이트 만들기', icon: '＋' },
  { id: 'domains', href: '/dashboard/domains', label: '도메인 관리', icon: '🔗' },
  { id: 'profile', href: '/dashboard/profile', label: '내 정보 관리', icon: '👤' },
  { id: 'billing', href: '/dashboard/billing', label: '결제 / 플랜', icon: '💳' },
];
---
<Base title={title}>
  <div class="cp-layout">
    <!-- Sidebar -->
    <aside id="sidebar" class="cp-sidebar">
      <!-- Logo -->
      <div class="cp-logo">
        <div class="cp-logo-icon">C</div>
        <span class="cp-logo-text">클라우드프레스</span>
      </div>

      <!-- Nav -->
      <nav class="cp-nav">
        {nav.map(item => (
          <a
            href={item.href}
            class={`cp-nav-item ${activeNav === item.id ? 'cp-nav-item--active' : ''}`}
          >
            <span class="cp-nav-icon">{item.icon}</span>
            <span>{item.label}</span>
          </a>
        ))}
        <!-- Admin nav — hidden by default, shown via JS only for admins -->
        <a href="/admin" id="admin-nav-item" class="cp-nav-item cp-nav-item--admin" style="display:none">
          <span class="cp-nav-icon">🛡️</span>
          <span>관리자 패널</span>
        </a>
      </nav>

      <!-- Bottom -->
      <div class="cp-sidebar-bottom">
        <button id="dark-toggle" class="cp-nav-item" style="width:100%;background:none;border:none;cursor:pointer;text-align:left;">
          <span id="dark-icon" class="cp-nav-icon">🌙</span>
          <span id="dark-label">다크 모드</span>
        </button>
        <button id="logout-btn" class="cp-nav-item cp-nav-item--danger" style="width:100%;background:none;border:none;cursor:pointer;text-align:left;">
          <span class="cp-nav-icon">🚪</span>
          <span>로그아웃</span>
        </button>
      </div>
    </aside>

    <!-- Mobile overlay -->
    <div id="sidebar-overlay" class="cp-overlay" onclick="closeSidebar()"></div>

    <!-- Main -->
    <div class="cp-main">
      <!-- Mobile topbar -->
      <header class="cp-topbar">
        <button onclick="openSidebar()" class="cp-topbar-menu" aria-label="메뉴">
          <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <span class="cp-topbar-title">클라우드프레스</span>
      </header>

      <!-- Announcement -->
      <div id="announcement-banner" class="cp-announcement" style="display:none">
        <span id="announcement-text"></span>
      </div>

      <!-- Page content -->
      <main class="cp-content">
        <slot />
      </main>
    </div>
  </div>

  <script>
    // Init: load user and show admin nav if needed
    async function initDashboard() {
      try {
        const res = await fetch('/api/profile');
        if (!res.ok) { window.location.href = '/login'; return; }
        const { data: user } = await res.json();
        if (!user) { window.location.href = '/login'; return; }

        if (user.role === 'admin') {
          const el = document.getElementById('admin-nav-item');
          if (el) el.style.display = 'flex';
        }

        (window as any)._cpUser = user;
        document.dispatchEvent(new CustomEvent('cp:user-loaded', { detail: user }));
      } catch {
        window.location.href = '/login';
      }
    }

    // Dark mode
    function updateDarkUI() {
      const isDark = document.documentElement.classList.contains('dark');
      const icon = document.getElementById('dark-icon');
      const label = document.getElementById('dark-label');
      if (icon) icon.textContent = isDark ? '☀️' : '🌙';
      if (label) label.textContent = isDark ? '라이트 모드' : '다크 모드';
    }
    document.getElementById('dark-toggle')?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('cp_dark', isDark ? '1' : '0');
      updateDarkUI();
    });
    updateDarkUI();

    // Logout
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/login';
    });

    // Sidebar mobile
    (window as any).openSidebar = () => {
      document.getElementById('sidebar')?.classList.add('cp-sidebar--open');
      document.getElementById('sidebar-overlay')?.classList.add('cp-overlay--show');
    };
    (window as any).closeSidebar = () => {
      document.getElementById('sidebar')?.classList.remove('cp-sidebar--open');
      document.getElementById('sidebar-overlay')?.classList.remove('cp-overlay--show');
    };

    // Announcement
    async function loadAnnouncement() {
      try {
        const res = await fetch('/api/admin?resource=settings');
        if (!res.ok) return;
        const { data } = await res.json();
        if (data?.ANNOUNCEMENT_ACTIVE === 'true' && data?.ANNOUNCEMENT_BANNER) {
          const banner = document.getElementById('announcement-banner');
          const text = document.getElementById('announcement-text');
          if (banner && text) {
            text.textContent = data.ANNOUNCEMENT_BANNER;
            banner.style.display = 'block';
          }
        }
      } catch {}
    }

    initDashboard();
    loadAnnouncement();
  </script>
</Base>

<style is:global>
  /* ── Reset body overflow ── */
  html, body { height: auto; min-height: 100vh; overflow-x: hidden; }

  /* ── Layout shell ── */
  .cp-layout {
    display: flex;
    min-height: 100vh;
  }

  /* ── Sidebar ── */
  .cp-sidebar {
    position: fixed;
    top: 0; left: 0; bottom: 0;
    width: 256px;
    background: white;
    border-right: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    z-index: 40;
    transform: translateX(-100%);
    transition: transform 0.2s ease;
  }
  .dark .cp-sidebar {
    background: #1e293b;
    border-right-color: #334155;
  }
  @media (min-width: 1024px) {
    .cp-sidebar { transform: none; }
  }
  .cp-sidebar--open { transform: translateX(0) !important; }

  /* ── Sidebar Logo ── */
  .cp-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 20px;
    border-bottom: 1px solid #e2e8f0;
    flex-shrink: 0;
  }
  .dark .cp-logo { border-bottom-color: #334155; }
  .cp-logo-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: #2563eb;
    color: white;
    font-weight: 700;
    font-size: 14px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .cp-logo-text {
    font-weight: 700;
    font-size: 16px;
    color: #0f172a;
  }
  .dark .cp-logo-text { color: white; }

  /* ── Nav ── */
  .cp-nav {
    flex: 1;
    padding: 12px;
    overflow-y: auto;
  }
  .cp-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    margin-bottom: 2px;
  }
  .dark .cp-nav-item { color: #94a3b8; }
  .cp-nav-item:hover { background: #f1f5f9; color: #0f172a; }
  .dark .cp-nav-item:hover { background: #334155; color: white; }
  .cp-nav-item--active { background: #eff6ff; color: #1d4ed8; }
  .dark .cp-nav-item--active { background: rgba(29,78,216,0.2); color: #60a5fa; }
  .cp-nav-item--danger { color: #dc2626; }
  .dark .cp-nav-item--danger { color: #f87171; }
  .cp-nav-item--danger:hover { background: #fef2f2; }
  .dark .cp-nav-item--danger:hover { background: rgba(220,38,38,0.15); }
  .cp-nav-icon { font-size: 16px; flex-shrink: 0; width: 20px; text-align: center; }

  /* ── Sidebar bottom ── */
  .cp-sidebar-bottom {
    padding: 12px;
    border-top: 1px solid #e2e8f0;
    flex-shrink: 0;
  }
  .dark .cp-sidebar-bottom { border-top-color: #334155; }

  /* ── Overlay ── */
  .cp-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 30;
  }
  .cp-overlay--show { display: block; }
  @media (min-width: 1024px) { .cp-overlay { display: none !important; } }

  /* ── Main area ── */
  .cp-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 100vh;
  }
  @media (min-width: 1024px) {
    .cp-main { margin-left: 256px; }
  }

  /* ── Mobile topbar ── */
  .cp-topbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: white;
    border-bottom: 1px solid #e2e8f0;
    position: sticky; top: 0; z-index: 20;
  }
  .dark .cp-topbar { background: #1e293b; border-bottom-color: #334155; }
  @media (min-width: 1024px) { .cp-topbar { display: none; } }
  .cp-topbar-menu {
    padding: 6px;
    border-radius: 6px;
    color: #64748b;
    background: none; border: none; cursor: pointer;
  }
  .cp-topbar-menu:hover { background: #f1f5f9; }
  .dark .cp-topbar-menu { color: #94a3b8; }
  .cp-topbar-title { font-weight: 700; color: #0f172a; }
  .dark .cp-topbar-title { color: white; }

  /* ── Announcement ── */
  .cp-announcement {
    background: #2563eb;
    color: white;
    font-size: 14px;
    text-align: center;
    padding: 8px 16px;
  }

  /* ── Content ── */
  .cp-content {
    flex: 1;
    padding: 24px 16px;
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
  }
  @media (min-width: 640px) { .cp-content { padding: 32px 24px; } }
  @media (min-width: 1024px) { .cp-content { padding: 32px; } }
</style>
