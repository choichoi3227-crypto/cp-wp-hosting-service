---
// src/pages/dashboard/create.astro
import Dashboard from '../../layouts/Dashboard.astro';
---
<Dashboard title="사이트 만들기" activeNav="create">
  <!-- Step indicator -->
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-1">클라우드플레어 워드프레스 호스팅</h1>
    <p class="text-slate-500 dark:text-slate-400 text-sm">헤드리스 방식으로 WordPress를 CMS로 사용하고 Cloudflare Workers가 모든 트래픽을 처리합니다.</p>
  </div>

  <!-- Progress steps -->
  <div class="flex items-center gap-2 mb-8 overflow-x-auto pb-2">
    {[
      { id: 1, label: '상품 확인' },
      { id: 2, label: 'WordPress 설정' },
      { id: 3, label: '기본 정보' },
      { id: 4, label: '프로비저닝' },
      { id: 5, label: '완료' },
    ].map((step, i) => (
      <div class="flex items-center gap-2 flex-shrink-0">
        {i > 0 && <div id={`arrow-${step.id}`} class="w-6 h-px bg-slate-200 dark:bg-slate-700 step-arrow" />}
        <div id={`step-${step.id}`} class="flex items-center gap-2 step-item">
          <div class={`w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold step-circle step-circle-${step.id} ${i === 0 ? 'bg-blue-600 text-white' : 'bg-slate-200 dark:bg-slate-700 text-slate-500'}`}>
            {step.id}
          </div>
          <span class={`text-sm font-medium step-label step-label-${step.id} ${i === 0 ? 'text-slate-900 dark:text-white' : 'text-slate-400'}`}>{step.label}</span>
        </div>
      </div>
    ))}
  </div>

  <!-- Step panels -->
  <div class="max-w-2xl">

    <!-- Step 1: Product confirm -->
    <div id="panel-1" class="step-panel">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-14 h-14 rounded-2xl bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-3xl flex-shrink-0">☁️</div>
          <div>
            <h2 class="text-lg font-bold text-slate-900 dark:text-white">클라우드플레어 워드프레스 호스팅</h2>
            <p class="text-slate-500 dark:text-slate-400 text-sm mt-1">헤드리스 WordPress + Cloudflare Workers</p>
          </div>
        </div>
        <div class="space-y-3 mb-8">
          {[
            '🚀 WordPress는 CMS 전용 — 서버 부하 제로',
            '⚡ Cloudflare Workers가 모든 트래픽 처리',
            '🔄 ISR + Webhook으로 콘텐츠 즉시 반영',
            '📦 GitHub에 미디어·파일 자동 저장',
            '🌐 무료 SSL + 글로벌 CDN 자동 적용',
            '🔌 모든 WordPress 플러그인 그대로 사용',
          ].map(f => (
            <div class="flex items-center gap-2.5 text-sm text-slate-700 dark:text-slate-300">
              <span class="flex-shrink-0">{f.split(' ')[0]}</span>
              <span>{f.split(' ').slice(1).join(' ')}</span>
            </div>
          ))}
        </div>
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-4 mb-6 text-sm text-amber-700 dark:text-amber-400">
          <strong>💡 시작 전 필요한 것:</strong>
          <ul class="mt-2 space-y-1 list-disc list-inside">
            <li>무료 WordPress 호스팅 (Byethost 권장)</li>
            <li>Cloudflare 글로벌 API 키 (내 정보 관리에서 설정)</li>
            <li>GitHub Personal Access Token (내 정보 관리에서 설정)</li>
          </ul>
        </div>
        <div id="creds-warning" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6 text-sm text-red-700 dark:text-red-400">
          ⚠️ <strong>Cloudflare API 키</strong> 또는 <strong>GitHub 토큰</strong>이 설정되지 않았습니다.
          <a href="/dashboard/profile" class="underline ml-1">내 정보 관리에서 설정하기 →</a>
        </div>
        <button onclick="goStep(2)" id="btn-step1"
          class="w-full py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold transition-colors disabled:opacity-50">
          시작하기 →
        </button>
      </div>
    </div>

    <!-- Step 2: WordPress setup -->
    <div id="panel-2" class="step-panel hidden">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-2">WordPress 설정</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">WordPress를 아직 만들지 않으셨나요? 아래 안내를 따라 무료로 설치하세요.</p>

        <!-- Byethost guide -->
        <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-xl p-4 mb-6">
          <h3 class="font-semibold text-blue-800 dark:text-blue-300 text-sm mb-2">📋 Byethost 무료 WordPress 설치 방법</h3>
          <ol class="text-sm text-blue-700 dark:text-blue-400 space-y-1.5 list-decimal list-inside">
            <li><a href="https://byethost.com" target="_blank" class="underline">byethost.com</a>에서 무료 계정 생성</li>
            <li>제어판 → Softaculous → WordPress 선택</li>
            <li>WordPress 설치 (관리자 계정 정보 기억)</li>
            <li>설치 완료 후 WordPress 관리자 URL 복사</li>
            <li>WordPress 관리자 → 사용자 → 애플리케이션 비밀번호 생성</li>
          </ol>
        </div>

        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
              WordPress 사이트 URL <span class="text-red-500">*</span>
            </label>
            <input id="wp-url" type="url" placeholder="https://mysite.byethost7.com"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm transition">
            <p class="text-xs text-slate-400 mt-1">설치된 WordPress 사이트의 전체 URL (wp-admin 제외)</p>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
              WordPress 관리자 이름 <span class="text-red-500">*</span>
            </label>
            <input id="wp-username" type="text" placeholder="admin"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
              애플리케이션 비밀번호 <span class="text-red-500">*</span>
            </label>
            <input id="wp-app-password" type="password" placeholder="xxxx xxxx xxxx xxxx xxxx xxxx"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm transition">
            <p class="text-xs text-slate-400 mt-1">WordPress 관리자 → 사용자 → 프로필 → 애플리케이션 비밀번호에서 생성</p>
          </div>
        </div>

        <div id="step2-msg" class="hidden mt-4 px-4 py-3 rounded-lg text-sm"></div>

        <div class="flex gap-3 mt-6">
          <button onclick="goStep(1)" class="flex-1 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
            ← 이전
          </button>
          <button onclick="verifyWP()" id="btn-verify-wp"
            class="flex-1 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-colors disabled:opacity-50">
            WordPress 연결 확인 →
          </button>
        </div>
      </div>
    </div>

    <!-- Step 3: Basic info -->
    <div id="panel-3" class="step-panel hidden">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8">
        <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-2">기본 정보</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">사이트 이름과 서브도메인을 설정해주세요.</p>

        <div id="wp-detected-badge" class="hidden bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-3 mb-5 text-sm text-green-700 dark:text-green-400">
          ✅ WordPress 연결 완료: <span id="wp-site-title-display"></span>
        </div>

        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
              사이트 이름 <span class="text-red-500">*</span>
            </label>
            <input id="site-name" type="text" placeholder="내 블로그"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm transition"
              oninput="autoSubdomain()">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
              서브도메인 <span class="text-red-500">*</span>
            </label>
            <div class="flex">
              <input id="subdomain" type="text" placeholder="my-blog"
                class="flex-1 px-3.5 py-2.5 rounded-l-lg border border-r-0 border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm transition"
                oninput="checkSubdomain()">
              <span class="px-3.5 py-2.5 bg-slate-100 dark:bg-slate-700 border border-slate-300 dark:border-slate-600 rounded-r-lg text-sm text-slate-500 dark:text-slate-400 whitespace-nowrap">.cloudpress.io</span>
            </div>
            <p id="subdomain-status" class="text-xs mt-1 text-slate-400">영문 소문자, 숫자, 하이픈만 사용 가능 (3~32자)</p>
          </div>
        </div>

        <div id="step3-msg" class="hidden mt-4 px-4 py-3 rounded-lg text-sm"></div>

        <div class="flex gap-3 mt-6">
          <button onclick="goStep(2)" class="flex-1 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
            ← 이전
          </button>
          <button onclick="startCreate()" id="btn-create"
            class="flex-1 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-colors disabled:opacity-50">
            사이트 만들기 →
          </button>
        </div>
      </div>
    </div>

    <!-- Step 4: Provisioning -->
    <div id="panel-4" class="step-panel hidden">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8 text-center">
        <div class="cp-spinner mx-auto mb-5"></div>
        <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4">사이트를 생성하는 중...</h2>
        <div class="space-y-3 text-left max-w-md mx-auto" id="prov-log"></div>
      </div>
    </div>

    <!-- Step 5: Complete -->
    <div id="panel-5" class="step-panel hidden">
      <div class="bg-white dark:bg-slate-800 rounded-2xl border border-slate-200 dark:border-slate-700 p-8 text-center">
        <div class="w-20 h-20 rounded-full bg-green-50 dark:bg-green-900/30 flex items-center justify-center text-4xl mx-auto mb-6">🎉</div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-2">사이트 생성 완료!</h2>
        <p class="text-slate-500 dark:text-slate-400 text-sm mb-6">헤드리스 WordPress 사이트가 성공적으로 배포되었습니다.</p>

        <div class="bg-slate-50 dark:bg-slate-700 rounded-xl p-4 mb-6 text-left space-y-3">
          <div>
            <p class="text-xs text-slate-500 mb-1">사이트 URL</p>
            <a id="result-url" href="#" target="_blank" class="text-blue-600 dark:text-blue-400 font-medium text-sm hover:underline break-all"></a>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-1">GitHub 저장소</p>
            <a id="result-repo" href="#" target="_blank" class="text-blue-600 dark:text-blue-400 font-medium text-sm hover:underline break-all"></a>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-1">Webhook URL (WordPress 플러그인에 입력)</p>
            <code id="result-webhook" class="text-xs bg-slate-200 dark:bg-slate-600 px-2 py-1 rounded break-all font-mono"></code>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-1">Webhook 시크릿</p>
            <code id="result-webhook-secret" class="text-xs bg-slate-200 dark:bg-slate-600 px-2 py-1 rounded break-all font-mono"></code>
          </div>
        </div>

        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-4 text-left text-sm text-amber-700 dark:text-amber-400 mb-6">
          <strong>📌 다음 단계 — CloudPress 플러그인 설치</strong>
          <ol class="mt-2 space-y-1.5 list-decimal list-inside">
            <li>WordPress 관리자 → 플러그인 → 새 플러그인 추가</li>
            <li>CloudPress Connector 플러그인 업로드 및 활성화</li>
            <li>설정에 Webhook URL과 시크릿 입력</li>
            <li>이제 글을 발행하면 즉시 헤드리스 사이트에 반영됩니다!</li>
          </ol>
        </div>

        <div class="flex gap-3">
          <a id="result-manage-link" href="/dashboard/sites" class="flex-1 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-medium text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
            사이트 관리
          </a>
          <a id="result-visit-link" href="#" target="_blank" class="flex-1 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-colors">
            사이트 방문 →
          </a>
        </div>
      </div>
    </div>

  </div>

  <script>
    let currentStep = 1;
    let wpSiteTitle = '';
    let createdSite: any = null;

    // Check credentials on load
    (async () => {
      try {
        const res = await fetch('/api/profile');
        const { data } = await res.json();
        if (!data.has_cf || !data.has_gh) {
          document.getElementById('creds-warning')?.classList.remove('hidden');
          const btn = document.getElementById('btn-step1') as HTMLButtonElement;
          if (btn) { btn.disabled = true; btn.textContent = '먼저 API 키를 설정해주세요'; }
        }
      } catch {}
    })();

    function goStep(n: number) {
      document.getElementById(`panel-${currentStep}`)?.classList.add('hidden');
      currentStep = n;
      document.getElementById(`panel-${n}`)?.classList.remove('hidden');

      // Update progress UI
      for (let i = 1; i <= 5; i++) {
        const circle = document.querySelector(`.step-circle-${i}`) as HTMLElement;
        const label = document.querySelector(`.step-label-${i}`) as HTMLElement;
        if (!circle || !label) continue;
        if (i < n) {
          circle.className = circle.className.replace(/bg-\w+-\d+\s+text-\w+/, '').trim();
          circle.classList.add('bg-green-500', 'text-white');
          circle.textContent = '✓';
          label.classList.remove('text-slate-400');
          label.classList.add('text-green-600', 'dark:text-green-400');
        } else if (i === n) {
          circle.className = circle.className.replace(/bg-\w+-\d+\s+text-\w+/, '').trim();
          circle.classList.add('bg-blue-600', 'text-white');
          label.classList.remove('text-slate-400');
          label.classList.add('text-slate-900', 'dark:text-white');
        } else {
          circle.className = circle.className.replace(/bg-\w+-\d+\s+text-\w+/, '').trim();
          circle.classList.add('bg-slate-200', 'dark:bg-slate-700', 'text-slate-500');
          label.classList.add('text-slate-400');
          label.classList.remove('text-slate-900', 'dark:text-white', 'text-green-600', 'dark:text-green-400');
        }
      }
    }
    (window as any).goStep = goStep;

    async function verifyWP() {
      const wpUrl = (document.getElementById('wp-url') as HTMLInputElement).value.trim();
      const wpUser = (document.getElementById('wp-username') as HTMLInputElement).value.trim();
      const wpPass = (document.getElementById('wp-app-password') as HTMLInputElement).value.trim();

      if (!wpUrl || !wpUser || !wpPass) {
        showStepMsg(2, '모든 항목을 입력해주세요.', 'error');
        return;
      }

      const btn = document.getElementById('btn-verify-wp') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = '연결 확인 중...';

      try {
        // Try to fetch WP site info directly
        let success = false;
        try {
          const wpInfoRes = await fetch(`${wpUrl}/wp-json/`, { mode: 'cors' });
          if (wpInfoRes.ok) {
            const info = await wpInfoRes.json() as any;
            wpSiteTitle = info?.name || '';
            success = true;
          } else {
            // Treat as success anyway — WP API may be restricted, actual verify happens on create
            success = true;
          }
        } catch {
          // CORS or network error — still proceed, final verify happens server-side
          success = true;
        }

        if (success) {
          if (wpSiteTitle) {
            (document.getElementById('site-name') as HTMLInputElement).value = wpSiteTitle;
            autoSubdomain();
          }
          const badge = document.getElementById('wp-detected-badge');
          const titleEl = document.getElementById('wp-site-title-display');
          if (badge && titleEl) {
            titleEl.textContent = wpSiteTitle || wpUrl;
            badge.classList.remove('hidden');
          }
          goStep(3);
        } else {
          showStepMsg(2, 'WordPress URL을 확인할 수 없습니다. URL을 확인해주세요.', 'error');
        }
      } catch {
        showStepMsg(2, '네트워크 오류가 발생했습니다.', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = 'WordPress 연결 확인 →';
      }
    }
    (window as any).verifyWP = verifyWP;

    function autoSubdomain() {
      const name = (document.getElementById('site-name') as HTMLInputElement).value;
      const slug = name.toLowerCase()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '')
        .slice(0, 32);
      if (slug.length >= 3) {
        (document.getElementById('subdomain') as HTMLInputElement).value = slug;
        checkSubdomain();
      }
    }
    (window as any).autoSubdomain = autoSubdomain;

    let subdomainTimer: any;
    function checkSubdomain() {
      clearTimeout(subdomainTimer);
      const val = (document.getElementById('subdomain') as HTMLInputElement).value;
      const statusEl = document.getElementById('subdomain-status')!;
      const re = /^[a-z0-9][a-z0-9-]{1,30}[a-z0-9]$/;
      if (!re.test(val)) {
        statusEl.className = 'text-xs mt-1 text-red-500';
        statusEl.textContent = '영문 소문자, 숫자, 하이픈만 사용 가능 (3~32자)';
        return;
      }
      statusEl.className = 'text-xs mt-1 text-slate-400';
      statusEl.textContent = '확인 중...';
      subdomainTimer = setTimeout(async () => {
        try {
          // Check via sites list — simpler than a dedicated endpoint
          const res = await fetch('/api/sites');
          if (res.ok) {
            const { data: sites = [] } = await res.json();
            const taken = (sites as any[]).some((s: any) => s.subdomain === val);
            statusEl.className = `text-xs mt-1 ${taken ? 'text-red-500' : 'text-green-500'}`;
            statusEl.textContent = taken ? '❌ 이미 사용 중인 서브도메인입니다.' : '✅ 사용 가능한 서브도메인입니다.';
          } else {
            statusEl.className = 'text-xs mt-1 text-green-500';
            statusEl.textContent = '✅ 사용 가능한 서브도메인입니다.';
          }
        } catch {
          statusEl.className = 'text-xs mt-1 text-slate-400';
          statusEl.textContent = '영문 소문자, 숫자, 하이픈만 사용 가능 (3~32자)';
        }
      }, 600);
    }
    (window as any).checkSubdomain = checkSubdomain;

    async function startCreate() {
      const name = (document.getElementById('site-name') as HTMLInputElement).value.trim();
      const subdomain = (document.getElementById('subdomain') as HTMLInputElement).value.trim();
      const wpUrl = (document.getElementById('wp-url') as HTMLInputElement).value.trim();
      const wpUser = (document.getElementById('wp-username') as HTMLInputElement).value.trim();
      const wpPass = (document.getElementById('wp-app-password') as HTMLInputElement).value.trim();

      if (!name || !subdomain) return showStepMsg(3, '사이트 이름과 서브도메인을 입력해주세요.', 'error');

      goStep(4);
      const logEl = document.getElementById('prov-log')!;
      const steps = [
        '🔍 WordPress 연결 확인 중...',
        '📦 GitHub 저장소를 생성하는 중...',
        '⚙️ Cloudflare Worker를 배포하는 중...',
        '🔗 도메인을 연결하는 중...',
      ];

      steps.forEach((text, i) => {
        setTimeout(() => {
          logEl.innerHTML += `<div class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400 animate-fade-in">
            <span class="cp-log-dot"></span> <span>${text}</span>
          </div>`;
        }, i * 1500);
      });

      try {
        const res = await fetch('/api/sites', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            subdomain,
            wp_url: wpUrl,
            wp_username: wpUser,
            wp_app_password: wpPass,
            wp_site_title: wpSiteTitle || name,
          }),
        });
        const data = await res.json();

        if (data.success) {
          createdSite = data.data.site;
          // Poll for completion
          await pollDeployment(data.data.deployment_id, logEl);
        } else {
          goStep(3);
          showStepMsg(3, data.error || '사이트 생성에 실패했습니다.', 'error');
        }
      } catch {
        goStep(3);
        showStepMsg(3, '네트워크 오류가 발생했습니다.', 'error');
      }
    }
    (window as any).startCreate = startCreate;

    async function pollDeployment(_deploymentId: string, _logEl: HTMLElement) {
      // Poll site status directly (no separate deployments endpoint needed)
      const maxAttempts = 40;
      for (let i = 0; i < maxAttempts; i++) {
        await new Promise(r => setTimeout(r, 3000));
        try {
          const siteRes = await fetch(`/api/sites/${createdSite.id}`);
          if (!siteRes.ok) continue;
          const { data: site } = await siteRes.json();
          if (site?.status === 'active') {
            showComplete(site);
            return;
          } else if (site?.status === 'error') {
            goStep(3);
            showStepMsg(3, '사이트 생성 중 오류가 발생했습니다. 다시 시도해주세요.', 'error');
            return;
          }
        } catch {}
      }
      // Timeout — show whatever we have
      try {
        const siteRes = await fetch(`/api/sites/${createdSite.id}`);
        const { data: site } = await siteRes.json();
        showComplete(site || createdSite);
      } catch { showComplete(createdSite); }
    }

    function showComplete(site: any) {
      goStep(5);
      const url = site.cf_worker_url || `https://${site.subdomain}.cloudpress.io`;
      const webhookUrl = `${location.origin}/api/webhook/${site.id}`;
      const el = (id: string) => document.getElementById(id);

      (el('result-url') as HTMLAnchorElement)!.href = url;
      (el('result-url') as HTMLAnchorElement)!.textContent = url;
      (el('result-repo') as HTMLAnchorElement)!.href = site.gh_repo_url || '#';
      (el('result-repo') as HTMLAnchorElement)!.textContent = site.gh_repo_full_name || '생성 중...';
      el('result-webhook')!.textContent = webhookUrl;
      el('result-webhook-secret')!.textContent = site.webhook_secret || '–';
      (el('result-visit-link') as HTMLAnchorElement)!.href = url;
      (el('result-manage-link') as HTMLAnchorElement)!.href = `/dashboard/sites/${site.id}`;
    }

    function showStepMsg(step: number, text: string, type: 'error' | 'success') {
      const el = document.getElementById(`step${step}-msg`)!;
      el.textContent = text;
      el.className = `mt-4 px-4 py-3 rounded-lg text-sm ${
        type === 'error'
          ? 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800'
          : 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800'
      }`;
      el.classList.remove('hidden');
    }
  </script>

  <style>
    @keyframes fade-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
    .animate-fade-in { animation: fade-in 0.3s ease; }
    /* CSS spinner — no emoji spinning */
    .cp-spinner {
      width: 48px; height: 48px;
      border: 4px solid #e2e8f0;
      border-top-color: #2563eb;
      border-radius: 50%;
      animation: cp-spin 0.8s linear infinite;
    }
    .cp-log-dot {
      display: inline-block;
      width: 8px; height: 8px;
      background: #2563eb;
      border-radius: 50%;
      flex-shrink: 0;
      animation: cp-pulse 1s ease-in-out infinite;
    }
    @keyframes cp-spin { to { transform: rotate(360deg); } }
    @keyframes cp-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  </style>
</Dashboard>
