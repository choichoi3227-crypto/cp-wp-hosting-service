---
// src/pages/dashboard/index.astro
import Dashboard from '../../layouts/Dashboard.astro';
---
<Dashboard title="대시보드" activeNav="dashboard">
  <!-- Header -->
  <div class="mb-8">
    <h1 id="greeting" class="text-2xl font-bold text-slate-900 dark:text-white">안녕하세요 👋</h1>
    <p class="text-slate-500 dark:text-slate-400 mt-1">클라우드프레스 대시보드에 오신 것을 환영합니다.</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5">
      <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">운영 중인 사이트</p>
      <p id="stat-sites" class="text-3xl font-bold text-slate-900 dark:text-white mt-1">–</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5">
      <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">연결된 도메인</p>
      <p id="stat-domains" class="text-3xl font-bold text-slate-900 dark:text-white mt-1">–</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5">
      <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">이번 달 배포</p>
      <p id="stat-deploys" class="text-3xl font-bold text-slate-900 dark:text-white mt-1">–</p>
    </div>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5">
      <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wide">현재 플랜</p>
      <p id="stat-plan" class="text-lg font-bold text-blue-600 dark:text-blue-400 mt-1">–</p>
    </div>
  </div>

  <!-- Sites list -->
  <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700">
    <div class="flex items-center justify-between px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="font-semibold text-slate-900 dark:text-white">내 사이트</h2>
      <a href="/dashboard/create" class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition-colors">
        <span>＋</span> 새 사이트 만들기
      </a>
    </div>
    <div id="sites-container" class="p-6">
      <div class="text-center text-slate-400 py-8">사이트 목록을 불러오는 중...</div>
    </div>
  </div>

  <script>
    import { escapeHtml } from '../../lib/utils/escape.ts';

    function bindDashboardActions() {
      const container = document.getElementById('sites-container');
      if (!container || (container as any)._dashboardActionsBound) return;
      (container as any)._dashboardActionsBound = true;
      container.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest('[data-action="redeploy"]') as HTMLElement | null;
        if (!btn) return;
        redeploy(btn.dataset.id || '');
      });
    }

    const planNames: Record<string, string> = {
      free: '무료', starter: '스타터', pro: '프로', business: '비즈니스'
    };

    function statusBadge(status: string) {
      const map: Record<string, string> = {
        active: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
        building: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
        error: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
        pending: 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-400',
        suspended: 'bg-slate-100 text-slate-500 dark:bg-slate-700 dark:text-slate-500',
      };
      const labels: Record<string, string> = {
        active: '운영중', building: '빌드중', error: '오류', pending: '대기', suspended: '정지'
      };
      const cls = map[status] || map.pending;
      const label = labels[status] || status;
      const pulse = status === 'building' ? ' animate-pulse' : '';
      return `<span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${cls}${pulse}">${label}</span>`;
    }

    function timeAgo(dateStr: string) {
      if (!dateStr) return '–';
      const diff = Date.now() - new Date(dateStr).getTime();
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return '방금 전';
      if (mins < 60) return `${mins}분 전`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `${hrs}시간 전`;
      return `${Math.floor(hrs / 24)}일 전`;
    }

    async function loadDashboard() {
      try {
        const [profileRes, sitesRes, domainsRes] = await Promise.all([
          fetch('/api/profile'),
          fetch('/api/sites'),
          fetch('/api/domains'),
        ]);

        if (!profileRes.ok) { window.location.href = '/login'; return; }

        const { data: user } = await profileRes.json();
        const { data: sites = [] } = sitesRes.ok ? await sitesRes.json() : { data: [] };
        const { data: domains = [] } = domainsRes.ok ? await domainsRes.json() : { data: [] };

        // Greeting
        document.getElementById('greeting')!.textContent = `안녕하세요, ${user.name}님 👋`;

        // Stats
        const activeSites = sites.filter((s: any) => s.status === 'active').length;
        const activeDomains = domains.filter((d: any) => d.ns_status === 'active').length;
        document.getElementById('stat-sites')!.textContent = String(activeSites);
        document.getElementById('stat-domains')!.textContent = String(activeDomains);
        document.getElementById('stat-deploys')!.textContent = '–';
        document.getElementById('stat-plan')!.textContent = planNames[user.plan_id] || user.plan_id;

        // Month deploys
        try {
          const depRes = await fetch('/api/deployments?period=month');
          if (depRes.ok) {
            const { data: deps = [] } = await depRes.json();
            document.getElementById('stat-deploys')!.textContent = String(deps.length);
          }
        } catch {}

        // Sites grid
        const container = document.getElementById('sites-container')!;
        if (!sites.length) {
          container.innerHTML = `
            <div class="text-center py-12">
              <div class="text-4xl mb-3">🌐</div>
              <p class="text-slate-500 dark:text-slate-400 mb-4">아직 만든 사이트가 없습니다.</p>
              <a href="/dashboard/create" class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium transition-colors">
                ＋ 첫 번째 사이트 만들기
              </a>
            </div>`;
          return;
        }

        container.innerHTML = `<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          ${sites.map((s: any) => `
            <div class="border border-slate-200 dark:border-slate-700 rounded-xl p-5 hover:shadow-md transition-shadow">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h3 class="font-semibold text-slate-900 dark:text-white text-sm">${escapeHtml(s.name)}</h3>
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">${s.custom_domain || s.subdomain + '.cloudpress.io'}</p>
                </div>
                ${statusBadge(s.status)}
              </div>
              <div class="flex items-center gap-2 mb-4">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">☁️ Cloudflare</span>
              </div>
              <p class="text-xs text-slate-400 mb-4">마지막 배포: ${timeAgo(s.last_deployed_at)}</p>
              <div class="flex gap-2">
                <a href="/dashboard/sites/${s.id}" class="flex-1 text-center py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 transition-colors">
                  사이트 관리
                </a>
                <button type="button" data-action="redeploy" data-id="${s.id}" class="flex-1 py-1.5 rounded-lg border border-blue-200 dark:border-blue-800 text-xs font-medium text-blue-700 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors">
                  재배포
                </button>
              </div>
            </div>
          `).join('')}
        </div>`;
        bindDashboardActions();
      } catch (err) {
        console.error('Dashboard load error:', err);
      }
    }

    async function redeploy(siteId: string) {
      if (!confirm('재배포를 시작하시겠습니까?')) return;
      try {
        const res = await fetch(`/api/sites/${siteId}/redeploy`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          alert('재배포가 시작되었습니다. 잠시 후 완료됩니다.');
          loadDashboard();
        } else {
          alert(data.error || '재배포에 실패했습니다.');
        }
      } catch {
        alert('네트워크 오류가 발생했습니다.');
      }
    }
    (window as any).redeploy = redeploy;

    bindDashboardActions();
    loadDashboard();
  </script>
</Dashboard>
