---
// src/pages/login.astro
import Base from '../layouts/Base.astro';
---
<Base title="로그인 — 클라우드프레스">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-white to-indigo-50 dark:from-slate-900 dark:via-slate-900 dark:to-slate-800 px-4 py-12">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-600 text-white text-2xl font-black shadow-lg mb-4">C</div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">클라우드프레스에 오신 것을 환영합니다</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1 text-sm">헤드리스 WordPress 호스팅 서비스</p>
      </div>

      <!-- Card -->
      <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-slate-200 dark:border-slate-700 p-8">
        <!-- Error/Success message -->
        <div id="msg" class="hidden mb-4 px-4 py-3 rounded-lg text-sm"></div>

        <!-- Tabs -->
        <div class="flex rounded-lg bg-slate-100 dark:bg-slate-700 p-1 mb-6">
          <button id="tab-login" onclick="switchTab('login')" class="tab-btn flex-1 rounded-md py-2 text-sm font-medium transition-colors bg-white dark:bg-slate-600 text-slate-900 dark:text-white shadow-sm">
            로그인
          </button>
          <button id="tab-register" onclick="switchTab('register')" class="tab-btn flex-1 rounded-md py-2 text-sm font-medium transition-colors text-slate-500 dark:text-slate-400">
            회원가입
          </button>
        </div>

        <!-- Login Form -->
        <form id="form-login" class="space-y-4" onsubmit="handleLogin(event)">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">이메일</label>
            <input id="login-email" type="email" placeholder="you@example.com" autocomplete="email"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition">
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">비밀번호</label>
              <a href="/forgot-password" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">비밀번호를 잊으셨나요?</a>
            </div>
            <input id="login-password" type="password" placeholder="••••••••" autocomplete="current-password"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition">
          </div>
          <button type="submit" id="login-submit"
            class="w-full py-2.5 px-4 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
            이메일로 계속하기
          </button>
        </form>

        <!-- Register Form -->
        <form id="form-register" class="hidden space-y-4" onsubmit="handleRegister(event)">
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">이름</label>
            <input id="reg-name" type="text" placeholder="홍길동" autocomplete="name"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">이메일</label>
            <input id="reg-email" type="email" placeholder="you@example.com" autocomplete="email"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">비밀번호 <span class="text-slate-400 font-normal">(8자 이상)</span></label>
            <input id="reg-password" type="password" placeholder="••••••••" autocomplete="new-password"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition">
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">비밀번호 확인</label>
            <input id="reg-password2" type="password" placeholder="••••••••" autocomplete="new-password"
              class="w-full px-3.5 py-2.5 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-900 dark:text-white placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-sm transition">
          </div>
          <button type="submit" id="reg-submit"
            class="w-full py-2.5 px-4 rounded-lg bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
            회원가입
          </button>
        </form>

        <p class="text-center text-xs text-slate-400 mt-5">
          계속 진행하면 <a href="/terms" class="underline hover:text-slate-600">이용약관</a> 및 <a href="/privacy" class="underline hover:text-slate-600">개인정보처리방침</a>에 동의하는 것으로 간주됩니다.
        </p>
      </div>

      <p class="text-center text-xs text-slate-400 mt-6">© 2025 클라우드프레스. All rights reserved.</p>
    </div>
  </div>

  <script>
    // Check already logged in
    (async () => {
      try {
        const r = await fetch('/api/profile');
        if (r.ok) window.location.href = '/dashboard';
      } catch {}
    })();

    // Check URL for reason
    const params = new URLSearchParams(location.search);
    const reason = params.get('reason');
    if (reason) {
      const msgs: Record<string, string> = {
        expired: '세션이 만료되었습니다. 다시 로그인해주세요.',
        session_expired: '세션이 만료되었습니다. 다시 로그인해주세요.',
        suspended: '계정이 정지되었습니다. 고객센터에 문의해주세요.',
      };
      if (msgs[reason]) showMsg(msgs[reason], 'error');
    }

    function showMsg(text: string, type: 'error' | 'success') {
      const el = document.getElementById('msg')!;
      el.textContent = text;
      el.className = `mb-4 px-4 py-3 rounded-lg text-sm ${
        type === 'error'
          ? 'bg-red-50 dark:bg-red-900/30 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800'
          : 'bg-green-50 dark:bg-green-900/30 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800'
      }`;
      el.classList.remove('hidden');
    }

    function switchTab(tab: string) {
      const isLogin = tab === 'login';
      document.getElementById('form-login')!.classList.toggle('hidden', !isLogin);
      document.getElementById('form-register')!.classList.toggle('hidden', isLogin);
      const activeClass = 'bg-white dark:bg-slate-600 text-slate-900 dark:text-white shadow-sm';
      const inactiveClass = 'text-slate-500 dark:text-slate-400';
      const loginBtn = document.getElementById('tab-login')!;
      const regBtn = document.getElementById('tab-register')!;
      loginBtn.className = `tab-btn flex-1 rounded-md py-2 text-sm font-medium transition-colors ${isLogin ? activeClass : inactiveClass}`;
      regBtn.className = `tab-btn flex-1 rounded-md py-2 text-sm font-medium transition-colors ${!isLogin ? activeClass : inactiveClass}`;
      document.getElementById('msg')?.classList.add('hidden');
    }
    (window as any).switchTab = switchTab;

    async function handleLogin(e: Event) {
      e.preventDefault();
      const btn = document.getElementById('login-submit') as HTMLButtonElement;
      const email = (document.getElementById('login-email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('login-password') as HTMLInputElement).value;
      if (!email || !password) return showMsg('이메일과 비밀번호를 입력해주세요.', 'error');
      btn.disabled = true;
      btn.textContent = '로그인 중...';
      try {
        const res = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        const data = await res.json();
        if (data.success) {
          const redirect = params.get('redirect') || '/dashboard';
          window.location.href = redirect;
        } else {
          showMsg(data.error || '로그인에 실패했습니다.', 'error');
        }
      } catch {
        showMsg('네트워크 오류가 발생했습니다. 잠시 후 다시 시도해주세요.', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = '이메일로 계속하기';
      }
    }
    (window as any).handleLogin = handleLogin;

    async function handleRegister(e: Event) {
      e.preventDefault();
      const btn = document.getElementById('reg-submit') as HTMLButtonElement;
      const name = (document.getElementById('reg-name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('reg-email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('reg-password') as HTMLInputElement).value;
      const password2 = (document.getElementById('reg-password2') as HTMLInputElement).value;
      if (!name || !email || !password) return showMsg('모든 항목을 입력해주세요.', 'error');
      if (password !== password2) return showMsg('비밀번호가 일치하지 않습니다.', 'error');
      if (password.length < 8) return showMsg('비밀번호는 8자 이상이어야 합니다.', 'error');
      btn.disabled = true;
      btn.textContent = '가입 중...';
      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, password }),
        });
        const data = await res.json();
        if (data.success) {
          window.location.href = '/dashboard';
        } else {
          showMsg(data.error || '회원가입에 실패했습니다.', 'error');
        }
      } catch {
        showMsg('네트워크 오류가 발생했습니다. 잠시 후 다시 시도해주세요.', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = '회원가입';
      }
    }
    (window as any).handleRegister = handleRegister;
  </script>
</Base>
